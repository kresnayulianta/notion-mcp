{
  "name": "@kresnayulianta/notion-mcp",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "notion-mcp": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
